---
import "@fontsource/ibm-plex-sans/latin-400.css";
import "@fontsource/ibm-plex-sans/latin-600.css";

const basePath = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
		<link rel="icon" href={`${basePath}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="BitCraft map link generator for sharing resource, enemy, and player ID filters with a single URL."
		/>
		<meta http-equiv="Content-Security-Policy" content="default-src 'self'; connect-src 'self' https://bitcraft-map-link-generator.vercel.app; frame-src https://map.bitjita.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:;" />
		<title>BitCraft Map Link Generator</title>
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: #0d1117;
		color: #c9d1d9;
		font-family: "IBM Plex Sans", "Segoe UI", Helvetica, Arial, sans-serif;
	}

	main {
		min-height: 100%;
	}

	button,
	input,
	select,
	textarea {
		font: inherit;
	}
</style>
